{
  "manifest_version": 3,
  "name": "Lightning Fleet Tracker",
  "version": "2.0.0",
  "description": "Captures Turo competitor data for Lightning Fleet Dashboard — v2 with GraphQL support",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://turo.com/*",
    "https://api.turo.com/*",
    "https://*.turo.com/*",
    "https://api.github.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://turo.com/*", "https://*.turo.com/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lightning Fleet Tracker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
